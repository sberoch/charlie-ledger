# syntax=docker/dockerfile:1
# pnpm version is pinned literally by patch-monorepo.mjs (reads the root
# package.json `packageManager` field). 10.33.4 is the placeholder it fills.
FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@10.33.4 --activate
WORKDIR /app

# Prune the monorepo down to `web` and its workspace dependencies so changes to
# other apps don't invalidate the deps/builder cache layers below.
FROM base AS pruner
RUN npm install -g turbo@2.9.15
COPY . .
RUN turbo prune web --docker

FROM base AS deps
COPY --from=pruner /app/out/json/ ./
RUN pnpm install --frozen-lockfile

FROM base AS builder
# NEXT_PUBLIC_* is inlined at build time, so the api URL is a build-arg, not runtime env.
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_TELEMETRY_DISABLED=1

COPY --from=deps /app/ ./
COPY --from=pruner /app/out/full/ ./
RUN pnpm --filter=web... build

FROM base AS runner
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
WORKDIR /app

# Requires `output: "standalone"` + `outputFileTracingRoot` in next.config
# (added by patch-monorepo.mjs). standalone nests the server under apps/web/.
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
CMD ["node", "apps/web/server.js"]
